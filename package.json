{
  "name": "tuxdio",
  "version": "1.0.0",
  "description": "Portail Radio-Canada pour Linux",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.thefrogensource.tuxdio",
    "productName": "TuxDio",
    "linux": {
      "target": "AppImage",
      "category": "AudioVideo"
    }
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  }
}
